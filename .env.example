####################################################################
# mi_IPFS_Drive — Variables de entorno
# Copia este archivo a ".env.local" y rellena los valores.
####################################################################

# ------------------------------------------------------------------
# SUPABASE (Auth + Postgres + Realtime + Edge Functions)
# Gratis: https://supabase.com — Free tier: 500MB DB, 50k MAU auth,
# 1GB storage de archivos (no lo usamos, guardamos solo metadatos),
# Realtime incluido. Alternativa: Clerk (solo auth) + Neon/PlanetScale (DB).
# ------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Solo para Edge Functions / server actions con privilegios elevados. ¡NUNCA exponer al cliente!
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SUPABASE_PROJECT_ID=xxxxxxxxxxxx

# URL pública del sitio (para magic links / redirects de auth)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------------
# IPFS PINNING SERVICE — elige UNO como principal (IPFS_PINNING_PROVIDER)
# El código en src/lib/ipfs/pinning-provider.ts abstrae el proveedor,
# así que cambiar de servicio es solo cambiar esta variable + su API key.
#
# Comparativa free tier (2026), de mejor a peor para este proyecto:
#
#   1) FILEBASE      -> 5 GB storage gratis, S3-compatible, sin tarjeta,
#                        pinning real y persistente, muy estable.  [RECOMENDADO]
#                        https://filebase.com
#   2) 4EVERLAND     -> ~5 GB gratis, gateway rápido tipo CDN, buen soporte
#                        de Web3, requiere wallet o email.
#                        https://4everland.org
#   3) IPFS NINJA    -> free tier generoso orientado a hobby/dev, ideal
#                        para prototipos rápidos sin tarjeta.
#                        https://ipfs.ninja (revisar límites vigentes)
#   4) LIGHTHOUSE    -> pinning perpetuo pagado por archivo (modelo "pay once"),
#                        tiene tier gratuito de prueba. https://lighthouse.storage
#   5) PINATA        -> free tier limitado (1 GB / 500 archivos aprox en 2026),
#                        gran DX y gateway dedicado, bueno para MVP pequeño.
#                        https://pinata.cloud
#
# IPFS_PINNING_PROVIDER acepta: "filebase" | "4everland" | "ipfs-ninja" | "lighthouse" | "pinata"
# ------------------------------------------------------------------
IPFS_PINNING_PROVIDER=filebase

# --- Filebase (S3-compatible) ---
FILEBASE_ACCESS_KEY=
FILEBASE_SECRET_KEY=
FILEBASE_BUCKET=mi-ipfs-drive

# --- 4EVERLAND ---
FOUREVERLAND_API_KEY=
FOUREVERLAND_BUCKET=mi-ipfs-drive

# --- IPFS Ninja ---
IPFS_NINJA_API_KEY=

# --- Lighthouse.storage ---
LIGHTHOUSE_API_KEY=

# --- Pinata ---
PINATA_JWT=

# Gateway público a usar para previsualizar/servir archivos por CID.
# Si tu proveedor da gateway dedicado (más rápido), úsalo aquí.
NEXT_PUBLIC_IPFS_GATEWAY_URL=https://ipfs.io/ipfs

# ------------------------------------------------------------------
# ENCRIPTACIÓN CLIENTE-SIDE (opcional, Web Crypto API)
# Si se activa, los archivos "privados" se cifran en el navegador con
# AES-GCM antes de subir a IPFS. La clave nunca sale del navegador
# (se deriva del password de sesión / se guarda en el metadata cifrado).
# ------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_CLIENT_ENCRYPTION=true

# ------------------------------------------------------------------
# HOSTING
# Frontend: Vercel (free tier: 100GB bandwidth, deploys ilimitados,
#            edge functions incluidas). Alternativa: Cloudflare Pages
#            (bandwidth ilimitado, buen fit si ya usas Workers).
# ------------------------------------------------------------------
